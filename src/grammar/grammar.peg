# Kero grammar
# This file is written in the "PackCC 1.8.0" grammar.

%prefix "KGParser"

%value "KGObject *"
%auxil "KGParserAuxil *"

%header {
#include "parser_auxil.h"
}

%source {
#include "parser_generated_include.h"
}

Module <- _ EndOfFile

_ <- (Whitespace / Comment)*

Comment <- SingleLineComment
SingleLineComment <- '//' (!EndOfLine .)* (EndOfLine / EndOfFile)

Whitespace <- [ \t]
EndOfLine <- '\n' / '\r\n' / '\r'
EndOfFile <- !.
