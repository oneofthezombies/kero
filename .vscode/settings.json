{
  "clangd.arguments": [
    "--header-insertion=never",
    "--query-driver=**",
    "--compile-commands-dir=${workspaceFolder}/build",

    "--compile-commands-dir=${env:HOME}/.local/share/compile_commands/googletest-1.14.0",
    "--compile-commands-dir=${env:HOME}/.local/share/compile_commands/llvm-project-llvmorg-18.1.4",
    "--compile-commands-dir=${env:HOME}/.local/share/compile_commands/cpp-tree-sitter-0.2.4"
  ],
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true,
    "editor.rulers": [80]
  },
  "[c]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true,
    "editor.rulers": [80]
  },
  "[cmake]": {
    "editor.defaultFormatter": "cheshirekow.cmake-format",
    "editor.formatOnSave": true,
    "editor.rulers": [80]
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.rulers": [80]
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.rulers": [80]
  }
}
