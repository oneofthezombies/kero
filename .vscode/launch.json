  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug Compiler Test",
      "program": "${workspaceFolder}/bazel-bin/kero_compiler_test",
      "args": [],
      "cwd": "${workspaceFolder}",
      "linux": {
        "sourceMap": {
          "/proc/self/cwd": "${workspaceFolder}"
        }
      },
      "osx": {
        "sourceMap": {
          ".": "${workspaceFolder}"
        }
      },
      "preLaunchTask": "Build Compiler Test"
    }
  ]
}
